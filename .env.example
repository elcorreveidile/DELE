# Base de datos PostgreSQL
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://usuario:password@localhost:5432/dele_platform"

# NextAuth.js - Autenticación
# Genera NEXTAUTH_SECRET con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secret-key-aqui-genera-una-aleatoria"
NEXTAUTH_URL="http://localhost:3000"

# OpenAI API (para chat con IA)
OPENAI_API_KEY="sk-tu-api-key-de-openai"

# Stripe (pagos)
STRIPE_SECRET_KEY="sk_test_tu-stripe-secret-key"
STRIPE_PUBLISHABLE_KEY="pk_test_tu-stripe-publishable-key"
STRIPE_WEBHOOK_SECRET="whsec_tu-webhook-secret"

# UploadThing (subida de archivos)
UPLOADTHING_SECRET="sk_live_tu-uploadthing-secret"
UPLOADTHING_APP_ID="tu-app-id"

# Configuración de entorno
NODE_ENV="development"
